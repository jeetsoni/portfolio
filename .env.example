# Palette agent (/api/agent). Set these in Railway's Variables tab for
# production, or copy this file to .env.local for local testing.
# The key comes from Vercel AI Gateway: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Optional: any model the gateway serves, in creator/model form.
# Defaults to deepseek/deepseek-v4-flash when unset (cheap, passed the
# tool-call + injection smoke test: scripts/agent-model-smoke.mjs).
# Upgrade path if answers ever feel weak: anthropic/claude-haiku-4.5
# AGENT_MODEL=deepseek/deepseek-v4-flash
